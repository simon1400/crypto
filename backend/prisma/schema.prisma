generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BotConfig {
  id                  Int      @id @default(1)
  apiKey              String?
  apiSecret           String?
  useTestnet          Boolean  @default(true)
  telegramBotToken    String?
  telegramChatId      String?
  telegramEnabled     Boolean  @default(false)
  // === Virtual trading simulation ===
  virtualBalance      Float    @default(1000)
  virtualBalanceStart Float    @default(1000)
  virtualStartedAt    DateTime @default(now())
  takerFeeRate        Float    @default(0.00055) // 0.055% — Bybit default VIP 0
  makerFeeRate        Float    @default(0.0002) // 0.02%  — Bybit default VIP 0
  // === MT5 calculator deposit (forex/gold position sizing) ===
  mt5Balance          Float?
  mt5RiskPct          Float    @default(2)
  mt5CommissionPerLot Float    @default(0)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

// =====================================================================
// Daily Breakout strategy — replaced Levels v2 on 2026-05-07.
// Range = first 3h UTC of each day → breakout in remaining 21h.
// =====================================================================

model BreakoutSignal {
  id               Int       @id @default(autoincrement())
  symbol           String
  side             String // BUY | SELL
  // Range definition (first 3h of UTC day)
  rangeHigh        Float
  rangeLow         Float
  rangeSize        Float
  rangeDate        String // 'YYYY-MM-DD' — UTC day
  // Trade levels
  entryPrice       Float
  stopLoss         Float
  initialStop      Float
  currentStop      Float
  tpLadder         Json
  // Volume confirmation
  volumeAtBreakout Float
  avgVolume        Float
  reason           String
  // Lifecycle
  status           String    @default("NEW") // NEW | ACTIVE | TP1_HIT | TP2_HIT | TP3_HIT | CLOSED | SL_HIT | EXPIRED
  closes           Json      @default("[]")
  realizedR        Float     @default(0)
  // Tracking
  lastPriceCheck   Float?
  lastPriceCheckAt DateTime?
  notifiedTelegram Boolean   @default(false)
  expiresAt        DateTime?
  closedAt         DateTime?
  createdAt        DateTime  @default(now())
  // Paper-trader outcome
  paperStatus      String?
  paperReason      String?
  paperUpdatedAt   DateTime?

  @@index([status, symbol])
  @@index([createdAt])
  @@index([rangeDate, symbol])
}

model BreakoutConfig {
  id               Int       @id @default(1)
  enabled          Boolean   @default(false)
  symbolsEnabled   Json      @default("[]")
  rangeBars        Int       @default(36)
  volumeMultiplier Float     @default(2.0)
  cronIntervalMin  Int       @default(5)
  notifyOnNew      Boolean   @default(true)
  notifyOnClose    Boolean   @default(true)
  lastScanAt       DateTime?
  lastScanResult   Json?
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())
}

model BreakoutPaperConfig {
  id                     Int       @id @default(1)
  enabled                Boolean   @default(false)
  startingDepositUsd     Float     @default(500)
  currentDepositUsd      Float     @default(500)
  riskPctPerTrade        Float     @default(2.0)
  // Legacy flat round-trip fee — kept for backwards compatibility.
  // When feeTakerPct / feeMakerPct are set, the trader uses the realistic
  // per-event model (entry taker, TP maker, SL/EXPIRED taker) and ignores this.
  feesRoundTripPct       Float     @default(0.08)
  // Realistic Binance-style fee model (defaults match Binance USDT-M perp base tier).
  feeTakerPct            Float     @default(0.05)  // entry market + SL/EXPIRED market
  feeMakerPct            Float     @default(0.02)  // TP limit fills
  slipTakerPct           Float     @default(0.03)  // slippage on taker fills only
  autoTrailingSL         Boolean   @default(false)
  // Margin guard
  targetMarginPct        Float     @default(10)
  marginGuardEnabled     Boolean   @default(true)
  marginGuardAutoClose   Boolean   @default(false)
  // Circuit breakers
  dailyLossLimitPct      Float     @default(5)
  weeklyLossLimitPct     Float     @default(15)
  maxConcurrentPositions Int       @default(10)
  maxPositionsPerSymbol  Int       @default(1)
  // Stats
  totalTrades            Int       @default(0)
  totalWins              Int       @default(0)
  totalLosses            Int       @default(0)
  totalPnLUsd            Float     @default(0)
  peakDepositUsd         Float     @default(500)
  maxDrawdownPct         Float     @default(0)
  startedAt              DateTime  @default(now())
  resetAt                DateTime?
  updatedAt              DateTime  @updatedAt
  createdAt              DateTime  @default(now())
}

model BreakoutPaperTrade {
  id                Int       @id @default(autoincrement())
  signalId          Int
  symbol            String
  side              String
  entryPrice        Float
  stopLoss          Float
  initialStop       Float
  currentStop       Float
  tpLadder          Json
  // Sizing
  depositAtEntryUsd Float
  riskUsd           Float
  positionSizeUsd   Float
  positionUnits     Float
  leverage          Float?
  marginUsd         Float?
  // Lifecycle
  status            String    @default("OPEN")
  closes            Json      @default("[]")
  realizedR         Float     @default(0)
  realizedPnlUsd    Float     @default(0)
  feesPaidUsd       Float     @default(0)
  netPnlUsd         Float     @default(0)
  feesRoundTripPct  Float?
  // Per-trade overrides for realistic fee model (null = use config defaults)
  feeTakerPct       Float?
  feeMakerPct       Float?
  slipTakerPct      Float?
  // Realised slip USD (reporting only)
  slipPaidUsd       Float     @default(0)
  autoTrailingSL    Boolean?
  // Tracking
  lastPriceCheck    Float?
  lastPriceCheckAt  DateTime?
  expiresAt         DateTime?
  closedAt          DateTime?
  openedAt          DateTime  @default(now())

  @@index([status, symbol])
  @@index([openedAt])
  @@index([signalId])
}

// === Variant B (parallel paper-trader copy with different sizing) ===
// Stores config and trades for a parallel B-copy of the Daily Breakout paper trader.
// Reads the same BreakoutSignal stream as A, but opens BreakoutPaperTradeB rows with
// its own deposit, sizing, and concurrency limits. Defaults match the backtested
// alternative configuration (20 conc, 5% target margin, $320 starting deposit).

model BreakoutPaperConfigB {
  id                     Int       @id @default(1)
  enabled                Boolean   @default(false)
  startingDepositUsd     Float     @default(320)
  currentDepositUsd      Float     @default(320)
  riskPctPerTrade        Float     @default(2.0)
  // Legacy flat round-trip fee (see BreakoutPaperConfig for behaviour notes).
  feesRoundTripPct       Float     @default(0.08)
  // Realistic Binance-style fee model (same defaults as variant A).
  feeTakerPct            Float     @default(0.05)
  feeMakerPct            Float     @default(0.02)
  slipTakerPct           Float     @default(0.03)
  autoTrailingSL         Boolean   @default(false)
  // Margin guard
  targetMarginPct        Float     @default(5)
  marginGuardEnabled     Boolean   @default(true)
  marginGuardAutoClose   Boolean   @default(false)
  // Circuit breakers
  dailyLossLimitPct      Float     @default(5)
  weeklyLossLimitPct     Float     @default(15)
  maxConcurrentPositions Int       @default(20)
  maxPositionsPerSymbol  Int       @default(1)
  // Scale-in UP (pyramiding): при fill primary автоматически выставляем limit
  // на цене (entry + triggerPct% * (TP1 - entry)) с размером primary * sizePct%.
  // Backtest (33%/75%) для B показал улучшение с +6% до +108% годовых на FULL.
  // По умолчанию выключено (false) — feature flag для безопасной выкатки.
  scaleInEnabled         Boolean   @default(false)
  scaleInTriggerPct      Float     @default(33)
  scaleInSizePct         Float     @default(75)
  // Stats
  totalTrades            Int       @default(0)
  totalWins              Int       @default(0)
  totalLosses            Int       @default(0)
  totalPnLUsd            Float     @default(0)
  peakDepositUsd         Float     @default(320)
  maxDrawdownPct         Float     @default(0)
  startedAt              DateTime  @default(now())
  resetAt                DateTime?
  updatedAt              DateTime  @updatedAt
  createdAt              DateTime  @default(now())
}

model BreakoutPaperTradeB {
  id                Int       @id @default(autoincrement())
  signalId          Int
  symbol            String
  side              String
  entryPrice        Float
  stopLoss          Float
  initialStop       Float
  currentStop       Float
  tpLadder          Json
  // Sizing
  depositAtEntryUsd Float
  riskUsd           Float
  positionSizeUsd   Float
  positionUnits     Float
  leverage          Float?
  marginUsd         Float?
  // Lifecycle
  status            String    @default("OPEN")
  closes            Json      @default("[]")
  realizedR         Float     @default(0)
  realizedPnlUsd    Float     @default(0)
  feesPaidUsd       Float     @default(0)
  netPnlUsd         Float     @default(0)
  feesRoundTripPct  Float?
  // Per-trade overrides for realistic fee model (null = use config defaults)
  feeTakerPct       Float?
  feeMakerPct       Float?
  slipTakerPct      Float?
  // Realised slip USD (reporting only)
  slipPaidUsd       Float     @default(0)
  autoTrailingSL    Boolean?
  // Tracking
  lastPriceCheck    Float?
  lastPriceCheckAt  DateTime?
  expiresAt         DateTime?
  closedAt          DateTime?
  openedAt          DateTime  @default(now())
  // Scale-in UP (pyramiding) — добавлено 2026-05-11.
  // tradeType:
  //   'PRIMARY'   — обычная сделка (market entry, как было до scale-in)
  //   'SCALE_IN'  — добавочная позиция, открывается limit-ордером на цене
  //                 (primary.entry + triggerPct% * (TP1 - primary.entry)).
  //                 SCALE_IN row создаётся вместе с primary, начинает жизнь
  //                 в limitOrderState='PENDING_LIMIT' и status='PENDING'.
  //                 При срабатывании limit переходит в status='OPEN' и
  //                 trackOnePaper подхватывает её как обычную позицию.
  // parentTradeId — на SCALE_IN указывает на PRIMARY (для cancel cascade
  //                 при SL primary и для UI inline-отображения).
  tradeType         String    @default("PRIMARY")
  parentTradeId     Int?
  // limitOrderState (только для SCALE_IN):
  //   PENDING_LIMIT — limit висит, ждёт срабатывания
  //   FILLING       — atomic claim (промежуточное)
  //   FILLED        — limit сработал, позиция открыта (status='OPEN')
  //   CANCELLED_PRIMARY_DONE — primary закрылась (SL/TP3/EXPIRED) до fill scale-in
  //   CANCELLED_EOD — лимит не сработал к 23:55 UTC, отменён
  limitOrderState   String?
  limitOrderPrice   Float?
  limitPlacedAt     DateTime?
  limitFilledAt     DateTime?

  @@index([status, symbol])
  @@index([openedAt])
  @@index([signalId])
  @@index([parentTradeId])
  @@index([limitOrderState, symbol])
}

// === Variant C — limit-on-rangeEdge experimental copy ===
// Schema-копия B + поля для limit-order lifecycle. Логика: при формировании
// 3h range движок выставляет 2 PENDING_LIMIT (BUY @ rangeHigh, SELL @ rangeLow).
// При срабатывании одного — второй CANCELLED_OTHER_SIDE. EOD не сработавшие
// CANCELLED_EOD. PENDING_LIMIT занимает concurrent slot.
// См. project_breakout_limit_entry_finding_2026_05_10.md.
model BreakoutPaperConfigC {
  id                     Int       @id @default(1)
  enabled                Boolean   @default(false)
  startingDepositUsd     Float     @default(320)
  currentDepositUsd      Float     @default(320)
  riskPctPerTrade        Float     @default(2.0)
  feesRoundTripPct       Float     @default(0.07)
  feeTakerPct            Float     @default(0.05)
  feeMakerPct            Float     @default(0.02)
  slipTakerPct           Float     @default(0.03)
  autoTrailingSL         Boolean   @default(true)
  targetMarginPct        Float     @default(5)
  marginGuardEnabled     Boolean   @default(true)
  marginGuardAutoClose   Boolean   @default(false)
  dailyLossLimitPct      Float     @default(5)
  weeklyLossLimitPct     Float     @default(15)
  maxConcurrentPositions Int       @default(20)
  maxPositionsPerSymbol  Int       @default(1)
  totalTrades            Int       @default(0)
  totalWins              Int       @default(0)
  totalLosses            Int       @default(0)
  totalPnLUsd            Float     @default(0)
  peakDepositUsd         Float     @default(320)
  maxDrawdownPct         Float     @default(0)
  startedAt              DateTime  @default(now())
  resetAt                DateTime?
  updatedAt              DateTime  @updatedAt
  createdAt              DateTime  @default(now())
}

model BreakoutPaperTradeC {
  id                Int       @id @default(autoincrement())
  signalId          Int
  symbol            String
  side              String
  entryPrice        Float
  stopLoss          Float
  initialStop       Float
  currentStop       Float
  tpLadder          Json
  depositAtEntryUsd Float
  riskUsd           Float
  positionSizeUsd   Float
  positionUnits     Float
  leverage          Float?
  marginUsd         Float?
  status            String    @default("OPEN")
  closes            Json      @default("[]")
  realizedR         Float     @default(0)
  realizedPnlUsd    Float     @default(0)
  feesPaidUsd       Float     @default(0)
  netPnlUsd         Float     @default(0)
  feesRoundTripPct  Float?
  feeTakerPct       Float?
  feeMakerPct       Float?
  slipTakerPct      Float?
  slipPaidUsd       Float     @default(0)
  autoTrailingSL    Boolean?
  lastPriceCheck    Float?
  lastPriceCheckAt  DateTime?
  expiresAt         DateTime?
  closedAt          DateTime?
  openedAt          DateTime  @default(now())
  // Limit-order lifecycle (специфично для C)
  // limitOrderState: PENDING_LIMIT, FILLED, CANCELLED_EOD, CANCELLED_OTHER_SIDE
  limitOrderState   String?
  limitOrderPrice   Float?
  limitPlacedAt     DateTime?
  limitFilledAt     DateTime?
  // pairOrderId — id противоположного лимита от того же сигнала (для cancel cascade)
  pairOrderId       Int?

  @@index([status, symbol])
  @@index([openedAt])
  @@index([signalId])
  @@index([limitOrderState, symbol])
}

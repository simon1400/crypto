generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  coins      String
  marketData Json
  coinsData  Json
  result     String
}

model Signal {
  id              Int      @id @default(autoincrement())
  channel         String
  messageId       Int
  publishedAt     DateTime
  type            String   // LONG or SHORT
  coin            String
  leverage        Int
  entryMin        Float
  entryMax        Float
  stopLoss        Float
  takeProfits     Json     // Float[]
  status          String   @default("ENTRY_WAIT") // ENTRY_WAIT, ACTIVE, SL_HIT, TP1_HIT, TP2_HIT, ...
  entryFilledAt   DateTime?
  statusUpdatedAt DateTime?
  priceHistory    Json     @default("[]") // {time: number, price: number}[]
  createdAt       DateTime @default(now())

  @@unique([channel, messageId])
}

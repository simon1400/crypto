generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Signal {
  id              Int      @id @default(autoincrement())
  channel         String
  messageId       Int
  publishedAt     DateTime
  type            String   // LONG or SHORT
  coin            String
  leverage        Int
  entryMin        Float
  entryMax        Float
  stopLoss        Float
  takeProfits     Json     // Float[]
  status          String   @default("ENTRY_WAIT") // ENTRY_WAIT, ACTIVE, SL_HIT, TP1_HIT, TP2_HIT, ...
  category        String?  // Scalp, Risk Scalp, etc. -- for order type detection (D-02)
  entryFilledAt   DateTime?
  statusUpdatedAt DateTime?
  priceHistory    Json     @default("[]") // {time: number, price: number}[]
  createdAt       DateTime @default(now())

  positions       Position[]

  @@unique([channel, messageId])
}

model Position {
  id               Int       @id @default(autoincrement())
  symbol           String                              // e.g. BTCUSDT
  type             String                              // LONG or SHORT
  leverage         Int
  entryPrice       Float?                              // null until filled
  entryOrderId     String?                             // Bybit order ID
  entryOrderLinkId String?                             // our orderLinkId (sig-{signalId}-entry)
  qty              Float                               // position size in base coin
  margin           Float?                              // USDT margin used
  stopLoss         Float
  takeProfits      Json                                // number[] from signal
  tpOrderIds       Json      @default("[]")            // string[] Bybit TP order IDs
  closedPct        Float     @default(0)
  realizedPnl      Float     @default(0)
  fees             Float     @default(0)
  status           String    @default("PENDING_ENTRY")
  // PENDING_ENTRY, OPEN, PARTIALLY_CLOSED, CLOSED, SL_HIT, CANCELLED, CLOSED_EXTERNAL, EXPIRED
  signalId         Int?
  createdAt        DateTime  @default(now())
  filledAt         DateTime?
  closedAt         DateTime?

  signal           Signal?   @relation(fields: [signalId], references: [id])
  orderLogs        OrderLog[]

  @@index([entryOrderId])
  @@index([signalId])
}

model OrderLog {
  id          Int       @id @default(autoincrement())
  positionId  Int?
  signalId    Int?
  action      String
  // ORDER_PLACED, ORDER_FILLED, ORDER_CANCELLED, SL_TRIGGERED,
  // TP1_HIT, TP2_HIT, TP3_HIT, TP4_HIT, TP5_HIT,
  // TP_ORDER_PLACED, POSITION_CLOSED, CLOSED_EXTERNAL,
  // RECONCILE_MISMATCH, ERROR, EXPIRED
  details     Json      @default("{}")
  createdAt   DateTime  @default(now())

  position    Position? @relation(fields: [positionId], references: [id])
}

model GeneratedSignal {
  id            Int      @id @default(autoincrement())
  coin          String
  type          String                           // LONG or SHORT
  strategy      String                           // trend_follow / mean_revert / breakout
  score         Int                              // 0-100
  entry         Float
  stopLoss      Float
  takeProfits   Json                             // [{price: number, rr: number, close_pct?: number}]
  leverage      Int
  positionPct   Float                            // % of deposit to risk
  amount        Float    @default(0)             // actual position size in USDT (set when TAKEN)
  indicators    Json                             // snapshot of multi-TF indicators
  marketContext Json                             // fear&greed, regime, funding, OI, news, category, coinRegime, scoring context
  aiAnalysis    String?                          // GPT review text
  closes        Json     @default("[]")          // [{price, percent, pnl, pnlPercent, closedAt}]
  closedPct     Float    @default(0)             // total % closed (0-100)
  realizedPnl   Float    @default(0)             // realized P&L in USDT
  status        String   @default("NEW")         // NEW, TAKEN, PARTIALLY_CLOSED, CLOSED, SL_HIT, EXPIRED
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  takenAt       DateTime?
  closedAt      DateTime?
  // === Outcome tracking (for confidence calibration) ===
  mfe           Float?                           // Max Favorable Excursion (% from entry to best price)
  mae           Float?                           // Max Adverse Excursion (% from entry to worst price)
  outcomeAt     DateTime?                        // when outcome was determined (TP hit or SL hit)
  hitTp1        Boolean  @default(false)         // did price reach TP1
  hitTp2        Boolean  @default(false)         // did price reach TP2
  hitTp3        Boolean  @default(false)         // did price reach TP3
  hitSl         Boolean  @default(false)         // did price hit SL
  bestModel     String?                          // which entry model turned out best by hindsight
  // === New 3-layer scoring fields ===
  initialStop       Float?                       // original stop loss (never overwritten after BE/trailing)
  currentStop       Float?                       // current active stop loss (updated on BE/trailing)
  setupScore        Int?                         // new setup score 0-100
  setupCategory     String?                      // A_PLUS_READY / READY / WATCHLIST / IGNORE
  executionType     String?                      // ENTER_NOW_LONG / LIMIT_LONG / WAIT_CONFIRMATION / IGNORE
  entryModel        String?                      // aggressive / confirmation
  exchange          String   @default("bybit")   // bybit | bingx | binance | mexc
  // === Trade lifecycle tracking ===
  stopMovedToBe     Boolean  @default(false)     // was stop moved to breakeven?
  stopMoveReason    String?                      // reason for stop move
  trailingActivated Boolean  @default(false)     // is trailing stop active?
  trailingActivationTime DateTime?               // when trailing was activated
  tp1HitTimestamp   DateTime?                    // when TP1 was hit
  tp2HitTimestamp   DateTime?                    // when TP2 was hit
  tp3HitTimestamp   DateTime?                    // when TP3 was hit
  exitReason        String?                      // INITIAL_STOP, BE_STOP, TRAILING_STOP, MANUAL_EXIT, TIME_STOP, TP1_PARTIAL, etc.
  timeInTradeMin    Int?                         // time from entry to final exit in minutes

  @@index([status])
  @@index([coin])
}

model Trade {
  id            Int      @id @default(autoincrement())
  coin          String                           // BTCUSDT, ETHUSDT...
  type          String                           // LONG or SHORT
  leverage      Int      @default(1)             // 1x-125x
  entryPrice    Float                            // цена входа
  amount        Float                            // размер позиции в USDT (маржа)
  stopLoss      Float                            // стоп-лосс (current active SL)
  initialStop   Float?                           // original stop loss (never overwritten)
  currentStop   Float?                           // alias for stopLoss, updated on BE/trailing
  takeProfits   Json                             // [{price: number, percent: number}] — уровни TP и % закрытия
  closes        Json     @default("[]")          // [{price: number, percent: number, pnl: number, closedAt: string}]
  closedPct     Float    @default(0)             // суммарно закрыто % позиции (0-100)
  realizedPnl   Float    @default(0)             // реализованный P&L в USDT (без вычета fees/funding)
  status        String   @default("OPEN")        // OPEN, PARTIALLY_CLOSED, CLOSED, SL_HIT, CANCELLED
  source        String   @default("MANUAL")      // MANUAL, SIGNAL, SCANNER, ENTRY_ANALYZER
  entryOrderType String  @default("market")      // market (taker) / limit (maker) — определяет fee вхождения
  fees          Float    @default(0)             // суммарные trading fees (entry + exit)
  fundingPaid   Float    @default(0)             // суммарно уплачено funding (положительное = платил, отрицательное = получал)
  lastFundingAt DateTime?                        // последний снапшот funding (чтобы не начислять дважды)
  notes         String?                          // заметки
  openedAt      DateTime?
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  // === New trade lifecycle tracking ===
  stopMovedToBe     Boolean  @default(false)     // was stop moved to breakeven?
  stopMoveReason    String?                      // reason for stop move
  trailingActivated Boolean  @default(false)     // is trailing stop active?
  trailingActivationTime DateTime?               // when trailing was activated
  tp1HitTimestamp   DateTime?                    // when TP1 was hit
  tp2HitTimestamp   DateTime?                    // when TP2 was hit
  tp3HitTimestamp   DateTime?                    // when TP3 was hit
  exitReason        String?                      // INITIAL_STOP, BE_STOP, TRAILING_STOP, MANUAL_EXIT, TIME_STOP, etc.
  timeInTradeMin    Int?                         // time from entry to final exit in minutes
  // === Outcome tracking ===
  mfe           Float?                           // Max Favorable Excursion %
  mae           Float?                           // Max Adverse Excursion %

  @@index([status])
  @@index([coin])
}

model BotConfig {
  id                      Int      @id @default(1)
  apiKey                  String?
  apiSecret               String?
  useTestnet              Boolean  @default(true)
  positionSizePct         Float    @default(10)
  dailyLossLimitPct       Float    @default(5)
  orderTtlMinutes         Int      @default(60)
  tradingMode             String   @default("manual")
  eveningTraderCategories Json     @default("[]")
  telegramBotToken        String?
  telegramChatId          String?
  telegramEnabled         Boolean  @default(false)
  scannerCoins            Json     @default("[]")
  autoScanEnabled         Boolean  @default(false)
  autoScanIntervalMin     Int      @default(12)
  autoScanMinScore        Int      @default(80)
  // === Virtual trading simulation ===
  virtualBalance          Float    @default(1000)  // текущий виртуальный депозит USDT
  virtualBalanceStart     Float    @default(1000)  // стартовый депозит (для расчёта ROI)
  virtualStartedAt        DateTime @default(now()) // когда запущена симуляция
  takerFeeRate            Float    @default(0.00055) // 0.055% — Bybit default VIP 0
  makerFeeRate            Float    @default(0.0002)  // 0.02%  — Bybit default VIP 0
  updatedAt               DateTime @updatedAt
  createdAt               DateTime @default(now())
}

model TickerMapping {
  id              Int      @id @default(autoincrement())
  fromTicker      String   @unique
  toSymbol        String
  priceMultiplier Float    @default(1)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BotConfig {
  id                  Int      @id @default(1)
  apiKey              String?
  apiSecret           String?
  useTestnet          Boolean  @default(true)
  telegramBotToken    String?
  telegramChatId      String?
  telegramEnabled     Boolean  @default(false)
  // === Virtual trading simulation ===
  virtualBalance      Float    @default(1000)
  virtualBalanceStart Float    @default(1000)
  virtualStartedAt    DateTime @default(now())
  takerFeeRate        Float    @default(0.00055) // 0.055% — Bybit default VIP 0
  makerFeeRate        Float    @default(0.0002) // 0.02%  — Bybit default VIP 0
  // === MT5 calculator deposit (forex/gold position sizing) ===
  mt5Balance          Float?
  mt5RiskPct          Float    @default(2)
  mt5CommissionPerLot Float    @default(0)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

// =====================================================================
// Daily Breakout strategy — replaced Levels v2 on 2026-05-07.
// Range = first 3h UTC of each day → breakout in remaining 21h.
// =====================================================================

model BreakoutSignal {
  id               Int       @id @default(autoincrement())
  symbol           String
  side             String // BUY | SELL
  // Range definition (first 3h of UTC day)
  rangeHigh        Float
  rangeLow         Float
  rangeSize        Float
  rangeDate        String // 'YYYY-MM-DD' — UTC day
  // Trade levels
  entryPrice       Float
  stopLoss         Float
  initialStop      Float
  currentStop      Float
  tpLadder         Json
  // Volume confirmation
  volumeAtBreakout Float
  avgVolume        Float
  reason           String
  // Lifecycle
  status           String    @default("NEW") // NEW | ACTIVE | TP1_HIT | TP2_HIT | TP3_HIT | CLOSED | SL_HIT | EXPIRED
  closes           Json      @default("[]")
  realizedR        Float     @default(0)
  // Tracking
  lastPriceCheck   Float?
  lastPriceCheckAt DateTime?
  notifiedTelegram Boolean   @default(false)
  expiresAt        DateTime?
  closedAt         DateTime?
  createdAt        DateTime  @default(now())
  // Paper-trader outcome
  paperStatus      String?
  paperReason      String?
  paperUpdatedAt   DateTime?

  @@index([status, symbol])
  @@index([createdAt])
  @@index([rangeDate, symbol])
}

model BreakoutConfig {
  id               Int       @id @default(1)
  enabled          Boolean   @default(false)
  symbolsEnabled   Json      @default("[]")
  rangeBars        Int       @default(36)
  volumeMultiplier Float     @default(2.0)
  cronIntervalMin  Int       @default(5)
  notifyOnNew      Boolean   @default(true)
  notifyOnClose    Boolean   @default(true)
  lastScanAt       DateTime?
  lastScanResult   Json?
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())
}

model BreakoutPaperConfig {
  id                     Int       @id @default(1)
  enabled                Boolean   @default(false)
  startingDepositUsd     Float     @default(500)
  currentDepositUsd      Float     @default(500)
  riskPctPerTrade        Float     @default(2.0)
  feesRoundTripPct       Float     @default(0.08)
  autoTrailingSL         Boolean   @default(false)
  // Margin guard
  targetMarginPct        Float     @default(10)
  marginGuardEnabled     Boolean   @default(true)
  marginGuardAutoClose   Boolean   @default(false)
  // Circuit breakers
  dailyLossLimitPct      Float     @default(5)
  weeklyLossLimitPct     Float     @default(15)
  maxConcurrentPositions Int       @default(10)
  maxPositionsPerSymbol  Int       @default(1)
  // Stats
  totalTrades            Int       @default(0)
  totalWins              Int       @default(0)
  totalLosses            Int       @default(0)
  totalPnLUsd            Float     @default(0)
  peakDepositUsd         Float     @default(500)
  maxDrawdownPct         Float     @default(0)
  startedAt              DateTime  @default(now())
  resetAt                DateTime?
  updatedAt              DateTime  @updatedAt
  createdAt              DateTime  @default(now())
}

model BreakoutPaperTrade {
  id                Int       @id @default(autoincrement())
  signalId          Int
  symbol            String
  side              String
  entryPrice        Float
  stopLoss          Float
  initialStop       Float
  currentStop       Float
  tpLadder          Json
  // Sizing
  depositAtEntryUsd Float
  riskUsd           Float
  positionSizeUsd   Float
  positionUnits     Float
  leverage          Float?
  marginUsd         Float?
  // Lifecycle
  status            String    @default("OPEN")
  closes            Json      @default("[]")
  realizedR         Float     @default(0)
  realizedPnlUsd    Float     @default(0)
  feesPaidUsd       Float     @default(0)
  netPnlUsd         Float     @default(0)
  feesRoundTripPct  Float?
  autoTrailingSL    Boolean?
  // Tracking
  lastPriceCheck    Float?
  lastPriceCheckAt  DateTime?
  expiresAt         DateTime?
  closedAt          DateTime?
  openedAt          DateTime  @default(now())

  @@index([status, symbol])
  @@index([openedAt])
  @@index([signalId])
}

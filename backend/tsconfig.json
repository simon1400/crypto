{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/scalper/runBacktest365.ts",
    "src/scalper/runBacktest365_crypto.ts",
    "src/scalper/runBacktest365_crypto_v2.ts",
    "src/scalper/runBacktest365_forex.ts",
    "src/scalper/runBacktest365_retry.ts",
    "src/scalper/runBacktest365_polygon.ts",
    "src/scalper/polygonProbe.ts"
  ]
}
